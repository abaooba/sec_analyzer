# Copy this file to .env and fill in the values.
# `python-dotenv` loads .env at startup; never commit your real .env.

# Identifies your app to the SEC EDGAR API. Required.
# Format: "Name email@example.com" (SEC requires a contact).
SEC_USER_AGENT=

# API key for the Groq LLM (Llama 3.3 70B) used in llm_analysis.py.
GROQ_API_KEY=

# SQLAlchemy database URL. Defaults to a local SQLite file.
DATABASE_URL=sqlite:///sec_analyzer.db

# Directory where raw SEC filings are stored.
RAW_FILINGS_DIR=data/raw_filings

# HTTP request timeout in seconds.
REQUEST_TIMEOUT=30

# Rate limit for outbound requests (SEC allows up to ~10/sec).
MAX_REQUESTS_PER_SECOND=5
