# Copy this file to .env and fill in the values.
# `python-dotenv` loads .env at startup; never commit your real .env.

# Identifies your app to the SEC EDGAR API. Required.
# Format: "Name email@example.com" (SEC requires a contact).
SEC_USER_AGENT=

# API key for the Groq LLM (Llama 3.3 70B) used in llm_analysis.py.
GROQ_API_KEY=

# SQLAlchemy database URL. Defaults to a local SQLite file.
DATABASE_URL=sqlite:///sec_analyzer.db

# Directory where raw SEC filings are stored.
RAW_FILINGS_DIR=data/raw_filings

# HTTP request timeout in seconds.
REQUEST_TIMEOUT=30

# Rate limit for outbound requests (SEC allows up to ~10/sec).
MAX_REQUESTS_PER_SECOND=5

# Verify TLS certificates on outbound HTTP. Leave true (secure); set to false
# only behind a trusted TLS-intercepting proxy.
TLS_VERIFY=true

# Browser origins allowed to call the API (CORS), comma-separated. "*" allows any
# origin (fine for local dev); set an allowlist (e.g. https://app.example.com) in prod.
CORS_ALLOW_ORIGINS=*

# --- Factor attribution (/factor-attribution endpoint) ---
# Base URL of the Ken French Data Library (free Fama-French factor CSVs).
FACTOR_DATA_BASE_URL=https://mba.tuck.dartmouth.edu/pages/faculty/ken.french/ftp/
# Where the downloaded factor zips are cached on disk.
FACTOR_CACHE_DIR=data/factor_cache
# How long (hours) a cached factor zip is treated as fresh before re-downloading.
FACTOR_CACHE_TTL_HOURS=24
