# Copy this file to `.env` and fill in real values. NEVER commit your real .env.
# config.py loads these via python-dotenv at import time.

# SEC EDGAR requires a descriptive User-Agent (name + email) or it returns 403.
SEC_USER_AGENT="Your Name your.email@example.com"

# Groq API key for the LLM narrative layer — https://console.groq.com/keys
# Optional: without it the app degrades gracefully to the rule-based output.
GROQ_API_KEY=

# SQLAlchemy connection URL (defaults to a local SQLite file if unset).
DATABASE_URL=sqlite:///sec_analyzer.db

# Where downloaded raw filing HTML is cached on disk before parsing.
RAW_FILINGS_DIR=data/raw_filings

# HTTP request timeout, in seconds.
REQUEST_TIMEOUT=30

# Client-side SEC rate limit (requests/second), under the SEC fair-access policy.
MAX_REQUESTS_PER_SECOND=5
